@model DirectoryManager.Web.Models.Sponsorship.TypeOptionCardVm
@using System.Globalization
@using DirectoryManager.Data.Enums
@using DirectoryManager.Web.Helpers
@using Microsoft.Extensions.Caching.Memory
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor httpContextAccessor
@inject NowPayments.API.Interfaces.INowPaymentsService nowPaymentsService
@inject IMemoryCache memoryCache

@functions {
    private static string FormatUtcFull(DateTime utc) =>
        utc.ToString(DirectoryManager.Common.Constants.StringConstants.DateTimeFormat, CultureInfo.InvariantCulture) + " UTC";

    private static string FormatCountdown(DateTime utc, DateTime nowUtc)
    {
        var diff = utc - nowUtc;
        if (diff <= TimeSpan.Zero) return "expired";
        return $"{diff.Days}d {diff.Hours}h {diff.Minutes}m";
    }
}

@{
    var usd = CultureInfo.GetCultureInfo(DirectoryManager.Web.Constants.StringConstants.EnglishUS);
    var opt = Model.Option;
    var nowUtc = DateTime.UtcNow;

    var conversionResult = await CurrencyConversionHelper.GetConversionContextAsync(httpContextAccessor, memoryCache, nowPaymentsService);
    bool showConverted = conversionResult.showConverted;
    decimal conversionRate = conversionResult.conversionRate;

    var title = !string.IsNullOrWhiteSpace(opt.ScopeLabel)
        ? opt.ScopeLabel
        : opt.SponsorshipType.ToString();

    int? categoryId = opt.SponsorshipType == SponsorshipType.CategorySponsor ? Model.TypeId : null;
    int? subCategoryId = opt.SponsorshipType == SponsorshipType.SubcategorySponsor ? Model.TypeId : null;

    var eligible = Model.CanAdvertise;

    var poolHasCapacity =
        opt.PoolMaxSlots > 0 &&
        opt.PoolActiveCount < opt.PoolMaxSlots;

    var blockedByMainSubCap = opt.BlockedByMainSubcategoryCap;

    var availableNow = eligible && !opt.IsExtension && poolHasCapacity && !blockedByMainSubCap;

    var postStartCheckoutUrl =
        Url.Action("SelectListing", "SponsoredListing") ?? "/sponsoredlisting/selectlisting";

    var extendHref =
        Url.Action("SelectDuration", "SponsoredListing", new
        {
            directoryEntryId = Model.DirectoryEntryId,
            sponsorshipType = opt.SponsorshipType
        }) ?? "/sponsoredlisting/selectduration";

    var hasWaitlist = opt.Waitlist != null && opt.Waitlist.Count > 0;

    var waitlistUrl =
        (opt.Waitlist != null && !string.IsNullOrWhiteSpace(opt.Waitlist.BrowseUrl))
            ? opt.Waitlist.BrowseUrl
            : (Url.Action("Waitlist", "Sponsorship", new { type = opt.SponsorshipType, typeId = Model.TypeId }) ?? "");

    var nextExpire = (opt.ActiveSlots != null && opt.ActiveSlots.Any())
        ? opt.ActiveSlots.OrderBy(x => x.CampaignEndUtc).FirstOrDefault()
        : null;
}

<div class="card" style="padding:14px; border-radius:12px;">
    <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:12px;">
        <div>
            <h3 style="margin:0 0 6px 0;">@title</h3>

            <div style="opacity:.9;">
                @if (!eligible)
                {
                    <span><strong>Not eligible yet</strong> — you can still subscribe above.</span>
                }
                else if (opt.IsExtension)
                {
                    <span><strong>Active</strong> — you can extend anytime.</span>
                    @if (opt.YourActiveUntilUtc.HasValue)
                    {
                        <text>(</text>
                        <span style="opacity:.85;">until <strong>@FormatUtcFull(opt.YourActiveUntilUtc.Value)</strong></span>

                        <text>)</text>
                    }
                }
                else if (availableNow)
                {
                    <div class="orange-text">
                        Available now — proceed to checkout.
                    </div>
                }
                else
                {
                    if (opt.PoolMaxSlots > 0 && opt.PoolActiveCount >= opt.PoolMaxSlots)
                    {
                        <span><strong>Full right now</strong> — subscribe above to get notified.</span>
                    }
                    else
                    {
                        <span><strong>Not available right now</strong> — subscribe above to get notified.</span>
                    }
                }

                @if (opt.BlockedByMainSubcategoryCap && opt.NextOpeningForMainSubcategoryCapUtc.HasValue)
                {
                    <div style="margin-top:6px; opacity:.85;">
                        Main-per-subcategory cap reached. Next likely opening:
                        <strong>@FormatUtcFull(opt.NextOpeningForMainSubcategoryCapUtc.Value)</strong>
                        <span style="display:block; opacity:.85;">
                            in @FormatCountdown(opt.NextOpeningForMainSubcategoryCapUtc.Value, nowUtc)
                        </span>
                    </div>
                }
            </div>
        </div>

        <div style="text-align:right; min-width:120px;">
            <div style="opacity:.85;">
                Slots: <strong>@opt.PoolActiveCount</strong> / @opt.PoolMaxSlots
            </div>
        </div>
    </div>

    @if (opt.Offers != null && opt.Offers.Any())
    {
        <div style="margin-top:14px;">
            <div style="font-weight:600; margin-bottom:6px;">Pricing</div>

            <div class="table-wrapper">
                <table class="table" style="width:100%; margin:0;">
                    <thead>
                        <tr>
                            <th style="width:90px;">Days</th>
                            <th style="text-align:right;">USD</th>
                            <th style="text-align:right;">XMR</th>
                            <th style="text-align:right;">$/day</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in opt.Offers.OrderBy(x => x.Days))
                        {
                            <tr>
                                <td>@o.Days</td>
                                <td style="text-align:right;">@o.PriceUsd.ToString("C2", usd)</td>
                                <td style="text-align:right;">
                                    @DirectoryManager.Utilities.Helpers.CurrencyFormatter.Format(
                                    o.PriceUsd,
                                    conversionRate,
                                    conversionResult.selectedCurrency,
                                    false
                                    )
                                </td>
                                <td style="text-align:right;">@o.PricePerDay.ToString("C2", usd)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (nextExpire != null && nextExpire.CampaignEndUtc > nowUtc)
            {
                <div style="margin-top:10px; padding:10px; border-radius:10px; background:rgba(255,255,255,0.03);">
                    <div style="font-weight:600;">Next expiration</div>
                    <div style="opacity:.9; margin-top:4px;">
                        <strong>@nextExpire.ListingName</strong>
                        <span style="opacity:.85;">—</span>
                        <strong>@FormatUtcFull(nextExpire.CampaignEndUtc)</strong>
                        <span style="display:block; opacity:.85;">
                            in @FormatCountdown(nextExpire.CampaignEndUtc, nowUtc)
                        </span>
                    </div>
                </div>
            }
        </div>
    }
</div>